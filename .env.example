# Copy to .dev.vars (local) and set the real values in the Cloudflare Pages
# dashboard (Settings → Environment variables) for production.
# Both .env and .dev.vars are gitignored — never commit real secrets.

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Zoho CRM (direct API) — functions/api/custom-enquiry.js ----
# 1. Go to https://api-console.zoho.com.au and create a "Self Client".
# 2. Generate a grant code with scope: ZohoCRM.modules.leads.CREATE
# 3. Exchange the grant code for a refresh token (POST to
#    https://accounts.zoho.com.au/oauth/v2/token). Refresh tokens don't expire
#    unless revoked, so this only needs doing once.
ZOHO_CLIENT_ID=YOUR_ZOHO_CLIENT_ID
ZOHO_CLIENT_SECRET=YOUR_ZOHO_CLIENT_SECRET
ZOHO_REFRESH_TOKEN=YOUR_ZOHO_REFRESH_TOKEN
ZOHO_ACCOUNTS_DOMAIN=accounts.zoho.com.au
ZOHO_API_DOMAIN=www.zohoapis.com.au
