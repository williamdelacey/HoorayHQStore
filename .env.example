# Copy to .dev.vars (local) and set the real values in the Cloudflare Pages
# dashboard (Settings → Environment variables) for production.
# Both .env and .dev.vars are gitignored — never commit real secrets.

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Zoho CRM (direct API) — functions/api/custom-enquiry.js ----
# 1. Go to https://api-console.zoho.com.au and create a "Self Client".
# 2. Generate a grant code with scope: ZohoCRM.modules.leads.CREATE
# 3. Exchange the grant code for a refresh token (POST to
#    https://accounts.zoho.com.au/oauth/v2/token). Refresh tokens don't expire
#    unless revoked, so this only needs doing once.
ZOHO_CLIENT_ID=YOUR_ZOHO_CLIENT_ID
ZOHO_CLIENT_SECRET=YOUR_ZOHO_CLIENT_SECRET
ZOHO_REFRESH_TOKEN=YOUR_ZOHO_REFRESH_TOKEN
ZOHO_ACCOUNTS_DOMAIN=accounts.zoho.com.au
ZOHO_API_DOMAIN=www.zohoapis.com.au
# Optional: the Orders (Deals) pipeline stage applied to new paid orders.
# Must match a Stage that exists in your Orders pipeline. Defaults to "Paid".
ZOHO_ORDER_STAGE=Paid
# Scope needed when generating the Zoho self-client grant:
#   ZohoCRM.modules.ALL   (covers both Enquiries/Leads and Orders/Deals)

# ---- Gallery uploads — functions/api/gallery-upload.js & gallery-delete.js ----
# Single shared password Hannah enters on the private /upload page to add or
# remove gallery photos. Photos live in the R2 bucket bound as GALLERY_BUCKET
# (see wrangler.toml). Pick a strong value; set it in the Pages dashboard for prod.
GALLERY_UPLOAD_PASSWORD=choose-a-strong-password

# ---- Meta Conversions API — stripe-webhook.js (Purchase) & custom-enquiry.js (Lead) ----
# Server-side conversion events, de-duped with the browser pixel in analytics.js.
# Token: Events Manager → your dataset → Settings → Conversions API → Generate
# access token. It's a SECRET — set it in the Cloudflare Pages dashboard, never commit.
# META_PIXEL_ID is optional (defaults to the live pixel id baked into the code).
META_CAPI_TOKEN=YOUR_META_CAPI_ACCESS_TOKEN
META_PIXEL_ID=1285412236732839
